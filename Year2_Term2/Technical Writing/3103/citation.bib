@ARTICLE{10440088,
  author={Fontes, Miguel and De Almeida, João Dallyson Sousa and Cunha, António},
  journal={IEEE Access},
  title={Application of Example-Based Explainable Artificial Intelligence (XAI) for Analysis and Interpretation of Medical Imaging: A Systematic Review},
  year={2024},
  volume={12},
  pages={26419--26427},
  doi={10.1109/ACCESS.2024.3367606},
  note={Relevance: Systematic review of example-based XAI in medical imaging; anchors normalisation of reliability and representativeness metrics in Phase 2; extends faithfulness layer (Layer 1) coverage to non-saliency explanation methods. Cite in: Phase 1 corpus justification, Phase 2 normalisation, Phase 4 Layer 1.}
}

@ARTICLE{11355720,
  author={Fouad, Shereen and Hakobyan, Lilit and Ihongbe, Izegbua E. and Kavakli-Thorne, Manolya and Atkins, Sarah and Bhatia, Bahadar},
  journal={IEEE Access},
  title={Human-Centered User Interface Design for Explainable AI in Chest Radiology: A Multi-Phase Co-Design Approach},
  year={2026},
  volume={14},
  pages={12498--12513},
  doi={10.1109/ACCESS.2026.3653233},
  note={Relevance: Multi-phase co-design with chest radiologists; directly operationalises Layer 3 (human-centred trust) of the taxonomy — the most underrepresented layer in the corpus. Identifies visual clarity, contrastive structure, and uncertainty signalling as trust drivers independent of faithfulness scores. Cite in: Phase 3 tensions discussion, Phase 4 Layer 3.}
}

@ARTICLE{11271656,
  author={Bai, Samita and Nasir, Sidra and Khan, Rizwan Ahmed and Meyer, Alexandre and Konik, Hubert},
  journal={IEEE Access},
  title={Breast Cancer Diagnosis With Explainable Artificial Intelligence (XAI): Uncovering Strengths and Biases},
  year={2025},
  volume={13},
  pages={205197--205223},
  doi={10.1109/ACCESS.2025.3639184},
  note={Relevance: Systematic review of XAI bias in breast cancer detection; explicit SHAP and Grad-CAM sensitivity and pixel-level perturbation analyses; bias sensitivity under data distribution shift. Extends oncology sub-domain coverage and Layer 2 robustness evidence. Cite in: Phase 1 corpus justification, Phase 4 Layer 2, Tables 2 and 4.}
}

@ARTICLE{10328849,
  author={Liu, Wei and Zhao, Feng and Shankar, Achyut and Maple, Carsten and Peter, James Dinesh and Kim, Byung-Gyu and Slowik, Adam and Parameshachari, Bidare Divakarachari and Lv, Jianhui},
  journal={IEEE Journal of Biomedical and Health Informatics},
  title={Explainable AI for Medical Image Analysis in Medical Cyber-Physical Systems: Enhancing Transparency and Trustworthiness of IoMT},
  year={2025},
  volume={29},
  number={4},
  pages={2365--2376},
  doi={10.1109/JBHI.2023.3336721},
  note={Relevance: Transparency and trustworthiness metrics for XAI in IoMT-integrated medical imaging; demonstrates robustness failure under sparse observability — extends Layer 2 beyond adversarial settings. Cross-modality coverage supports Phase 3 alignment. Cite in: Phase 1 corpus justification, Phase 4 Layer 2, Tables 2 and 3.}
}

@ARTICLE{10051650,
  author={Major, David and Lenis, Dimitrios and Wimmer, Maria and Berg, Astrid and Neubauer, Theresa and Bühler, Katja},
  journal={IEEE Transactions on Medical Imaging},
  title={On the Importance of Domain Awareness in Classifier Interpretations in Medical Imaging},
  year={2023},
  volume={42},
  number={8},
  pages={2286--2298},
  doi={10.1109/TMI.2023.3247659},
  note={Relevance: Direct follow-up to Lenis et al. [11] by the same group; empirically shows that domain-unaware XAI interpretations produce clinically misleading attributions even when technically faithful. Strengthens the cross-domain alignment argument in Phase 3 and the case for domain-specific evaluation criteria. Cite in: Related Work, Phase 3 alignment, Phase 4 taxonomy cross-layer criteria.}
}

