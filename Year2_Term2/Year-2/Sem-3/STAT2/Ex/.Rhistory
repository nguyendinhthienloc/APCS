model2 <- lm(Betacaro ~ Linoleic + Kerosene + Antiox + I(Linoleic^2) + I(Kerosene^2) + I(Antiox^2) + Linoleic*Kerosene + Linoleic*Antiox + Kerosene*Antiox)
summary(model2)
PI <- predict(model2,newdata = data.frame(Linoleic = 30, Kerosene = 30, Antiox = 10),interval = "prediction")
