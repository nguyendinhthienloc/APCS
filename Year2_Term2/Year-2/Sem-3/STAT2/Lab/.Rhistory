### viet CI cho sigma^2
CI.sigma2 <- function(n, gamma, sample_data) {
S2 <- var(sample_data)  # Sample variance
alpha <- 1 - gamma  # Significance level
# Chi-squared critical values
chi2_lower <- qchisq(alpha / 2, df = n - 1)
chi2_upper <- qchisq(1 - alpha / 2, df = n - 1)
# Confidence interval for sigma^2
lower_bound <- (n - 1) * S2 / chi2_upper
upper_bound <- (n - 1) * S2 / chi2_lower
return(c(lower_bound, upper_bound))
}
# Example usage
sample_size <- 100
gamma <- 0.95
sample_data <- rnorm(sample_size, mean = 0, sd = 1)
CI <- CI.sigma2(sample_size, gamma, sample_data)
CI  # Returns the confidence interval for sigma^2
