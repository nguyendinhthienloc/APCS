mu <- 5
sigma <- 2
CI.mu <- function(n,gamma){
x <- rnorm(n,mu,sigma)
l <- mean(x)-qt((1+gamma)/2,n-1)*S/sqrt(n)
u <- mean(x)+qt((1+gamma)/2,n-1)*S/sqrt(n)
return (c(l,u))
}
CI.mu(50,0.95)
mu <- 5
sigma <- 2
CI.mu <- function(n,gamma){
x <- rnorm(n,mu,sigma)
l <- mean(x)-qt((1+gamma)/2,n-1)*sd(x)/sqrt(n)
u <- mean(x)+qt((1+gamma)/2,n-1)*sd(x)/sqrt(n)
return (c(l,u))
}
