n <- 1000
sample.mean <- function(n)
{
meanX <- c()
for (i in 1:n){
X <- rnorm(sample.size,mu,sigma)
meanX <- c(mean(X),meanX)
}
return (meanX)
}
sample.mean(50)
hist(sample.mean(50000),freq = F,breaks=500)
curve(dnorm(x,mu,sd=sigma/sqrt(sample.size)),add=T)
curve(dnorm(x,mu+3,sd=sigma/sqrt(sample.size)),add=T)
