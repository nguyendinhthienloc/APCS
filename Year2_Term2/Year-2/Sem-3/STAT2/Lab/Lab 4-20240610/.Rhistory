x <- c(.11 ,.13 ,.14 ,.18 ,.29 ,.44 ,.67 ,.78 ,.93)
y <- c(1.72 ,2.17 ,2.33 ,3.00 ,5.17 ,7.61 ,11.17 ,12.72 ,14.78)
model <- lm(y~x)
names(model)
library(Devore7)
intercept <- coef(model)[1]
slope <- coef(model)[2]
coefficients <- c(intercept,slope)
coefficients
summary(model)
x_new <- data.frame(x = c(0.2, 0.4))
predictions <- predict(model, newdata = x_new, se.fit = TRUE)
predictions$fit      # Predicted values (\hat{y})
predictions$se.fit   # Standard errors of the predictions (S_{\hat{y}})
mean(x)
predictions <- predict(model, newdata = 0.4, interval = "confidence", level = 0.95)
x_new <- data.frame(x=0.4)
predictions <- predict(model, newdata = 0.4, interval = "confidence", level = 0.95)
x_new <- data.frame(x = 0.4)
predictions <- predict(model, newdata = x_new, interval = "confidence", level = 0.95)
