output:
pdf_document: default
# Input the data
x1 <- c(0.93,1.11,0.93,1.11,0.93,1.11,0.93,1.11,1.02,1.02,1.02,1.02)
x2 <- c(1.00,1.00,1.00,1.00,1.40,1.40,1.40,1.40,1.18,1.18,1.18,1.18)
x3 <- c(0.20,0.20,0.50,0.50,0.20,0.20,0.50,0.50,0.31,0.31,0.31,0.31)
y <- c(32.95,38.72,35.20,38.72,32.27,39.71,33.67,38.72,35.20,33.67,36.02,32.27)
# Transform the variables using natural logarithms
ln_x1 <- log(x1)
ln_x2 <- log(x2)
ln_x3 <- log(x3)
ln_y <- log(y)
# Create a data frame
data <- data.frame(ln_x1, ln_x2, ln_x3, ln_y)
# Fit the linear regression model
model <- lm(ln_y ~ ln_x1 + ln_x2 + ln_x3, data = data)
# Display the summary of the model
model_summary <- summary(model)
model_summary
# Define the hypotheses
H0 <- "The model with the predictors ln(x1), ln(x2), and ln(x3) is not useful in predicting ln(y) (all coefficients are zero)"
HA <- "At least one of the predictors ln(x1), ln(x2), or ln(x3) is useful in predicting ln(y) (at least one coefficient is not zero)"
# Print the hypotheses
cat("Null Hypothesis (H0):", H0, "\n")
cat("Alternative Hypothesis (HA):", HA, "\n")
# Extract the F-statistic and p-value
f_statistic <- model_summary$fstatistic[1]
p_value <- pf(f_statistic, model_summary$fstatistic[2], model_summary$fstatistic[3], lower.tail = FALSE)
# Print the results
cat("F-statistic:", f_statistic, "\n")
cat("p-value:", p_value, "\n")
# Check the significance at 0.05 level
if(p_value < 0.05) {
cat("The model is significant at the 0.05 level.\n")
} else {
cat("The model is not significant at the 0.05 level.\n")
}
