title: "InClass Assignment"
x1 <- c(0.93,1.11,0.93,1.11,0.93,1.11,0.93,1.11,1.02,1.02,1.02,1.02)
x2 <- c(1.00,1.00,1.00,1.00,1.40,1.40,1.40,1.40,1.18,1.18,1.18,1.18)
x3 <- c(0.20,0.20,0.50,0.50,0.20,0.20,0.50,0.50,0.31,0.31,0.31,0.31)
y <- c(32.95,38.72,35.20,38.72,32.27,39.71,33.67,38.72,35.20,33.67,36.02,32.27)
e <- log(5)
x1 <- log(x1, e)
x2 <- log(x2, e)
x3 <- log(x3, e)
y <- log(y, e)
model <- lm(y ~ x1 + x2 + x3)
summary(model)
model1 <- lm(y ~ x1 + x3)
summary(model1)
model2 <- lm(y ~ x1)
summary(model2)
x1_square <- x1^2
model3 <- lm(y ~ x1 + x1_square)
summary(model3)
x <- log(1,e)
x_square <- log(1, e)^2
new_data <- data.frame(x,x_square)
predict(model3, newdata = new_data,interval = c("prediction"))
