data <- read.csv("D:/STAT/Ex61/ex13_56.csv")
# QUESTION
# In an experiment to study factors influencing wood specific gravity
# (ŌĆ£Anatomical Factors Influencing Wood
# Specific Gravity of Slash Pines and the Implications
# for the Development of a High-Quality Pulpwood,ŌĆØ
# TAPPI, 1964: 401ŌĆō404), a sample of 20 mature wood
# samples was obtained, and measurements were taken on
# the number of fibers/mm2 in springwood (x1), number of
# fibers/mm2 in summerwood (x2), % springwood (x3),
# light absorption in springwood (x4), and light absorption
# in summerwood (x5).
# The following R^2 values resulted from
# regressing each predictor on the other four predictors (in
# the first regression, the dependent variable was x1 and the
# predictors were x2ŌĆōx5, etc.): .628, .711, .341, .403, and
# .403. Does multicollinearity appear to be a substantial
# problem? Explain.
x1 <- data$Springwood.fibers
x2 <- data$Summerwood.fibers
x3 <- data$X..Springwood
x4 <- data$X..Springwood.light.absorption
x5 <- data$X..Summerwood.light.absorption
mod1 <- lm(x1 ~ x2 + x3 + x4 + x5)
summary(mod1)
# Multiple R-squared:  0.6568
mod2 <- lm(x2 ~ x1 + x3 + x4 + x5)
summary(mod2)
# Multiple R-squared:  0.7397
mod3 <- lm(x3 ~ x1 + x2 + x4 + x5)
summary(mod3)
# Multiple R-squared:  0.3156
mod4 <- lm(x4 ~ x1 + x2 + x3 + x5)
summary(mod4)
# Multiple R-squared:  0.2806
mod5 <- lm(x5 ~ x1 + x2 + x3 + x4)
summary(mod5)
# Multiple R-squared:  0.4268
# The R^2 values are not close to 1, so multicollinearity does not appear to be a substantial problem.
y <- data$Specific.gravity
mod <- lm(y~ x1 + x2 + x3 + x4 + x5)
summary(mod)
mod1 <- lm(x1 ~ x2 + x3 + x4 + x5)
summary(mod1)
mod2 <- lm(x2 ~ x1 + x3 + x4 + x5)
summary(mod2)
mod3 <- lm(x3 ~ x1 + x2 + x4 + x5)
summary(mod3)
mod4 <- lm(x4 ~ x1 + x2 + x3 + x5)
summary(mod4)
mod5 <- lm(x5 ~ x1 + x2 + x3 + x4)
summary(mod5)
x1 = c(0.93, 1.11, 0.93, 1.11, 0.93, 1.11, 0.93, 1.11, 1.02, 1.02, 1.02, 1.02)
x2 = c(1.00, 1.00, 1.00, 1.00, 1.40, 1.40, 1.40, 1.40, 1.18, 1.18, 1.18, 1.18)
x3 = c(0.20, 0.20, 0.50, 0.50, 0.20, 0.20, 0.50, 0.50, 0.31, 0.31, 0.31, 0.31)
y = c(32.95, 38.72, 35.20, 38.72, 32.27, 39.71, 33.67, 38.72, 35.20, 33.67, 36.02, 32.27)
ln_x1 = log(x1)
ln_x2 = log(x2)
ln_x3 = log(x3)
ln_y = log(y)
model4 = lm(ln_y ~ ln_x1 + I(ln_x1^2))
model4
summary(model4)
predict(model4, newdata = data.frame(ln_x1 = 0), interval = "prediction", level = 0.95)
lower_bound_prediction = exp(3.427711)
upper_bound_prediction = exp(3.609864)
lower_bound_prediction
upper_bound_prediction
